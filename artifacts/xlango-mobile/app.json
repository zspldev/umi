{
  "expo": {
    "name": "XLango",
    "slug": "xlango-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "xlango-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/xlango-mark.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2EBD9"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.zapurzaa.xlango",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/xlango-mark.png",
        "backgroundColor": "#F2EBD9"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b46f3828-3ddd-448d-bb24-0abeef7e664e"
      }
    }
  }
}
